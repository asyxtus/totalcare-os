# Copy this file to .env.local and fill in your real values.
# .env.local is git-ignored — never commit real keys.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key: SERVER-SIDE ONLY. Never reference this in any file
# that could be imported into a client component. Used only via
# lib/supabase/admin.ts, by privileged server actions like
# lib/actions/staffAdmin.ts (inviting/deactivating staff).
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Shared secret checked by app/api/cron/accrue-inpatient-charges — set
# this in Vercel's env vars too. Vercel Cron automatically sends it as
# a Bearer token when triggering scheduled routes; if calling from
# GitHub Actions instead, pass it as -H "Authorization: Bearer $CRON_SECRET".
CRON_SECRET=generate-a-long-random-value-here

# Separate secret for app/api/admin/provision-clinic — deliberately NOT
# the same value as CRON_SECRET. That one fires automatically every
# night; this one provisions a brand-new clinic tenant and should be
# something you type in by hand each time you actually mean to use it,
# not something baked into an automated schedule anywhere.
PLATFORM_ADMIN_SECRET=generate-a-different-long-random-value-here

# Direct Postgres connection string for the migration runner (scripts/migrate.mjs).
# Get it from: Supabase Dashboard → Settings → Database → Connection string
# → URI tab → "Session pooler" (recommended) or "Direct connection".
# Looks like: postgresql://postgres.xxxx:[PASSWORD]@aws-0-...pooler.supabase.com:5432/postgres
# This is server-side/CLI only — never imported into app code.
DATABASE_URL=postgresql://postgres.xxxx:[PASSWORD]@aws-0-region.pooler.supabase.com:5432/postgres

# Your real production URL — used to build invite/password-reset links so
# they never default to Supabase's dashboard "Site URL" setting (which
# defaults to http://localhost:3000 and is easy to forget to update).
NEXT_PUBLIC_SITE_URL=https://your-domain.vercel.app
